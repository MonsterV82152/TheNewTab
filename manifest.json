{
    "manifest_version": 3,
    "name": "Your NewTab",
    "version": "1.0.1",
    "description": "Nothing. Just a NewTab extension with random quote!",
    "browser_specific_settings": {
        "gecko": {
            "id": "your-newtab@fuongz.github.io",
            "strict_min_version": "109.0"
        }
    },
    "chrome_url_overrides": {
        "newtab": "newtab.html"
    },
    "permissions": [
        "storage"
    ],
    "icons": {
        "48": "icon.svg",
        "128": "icon.svg"
    },
    "action": {
        "default_icon": "icon.svg"
    }
}