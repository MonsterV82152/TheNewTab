{
    "manifest_version": 3,
    "name": "Your NewTab",
    "version": "1.0.1",
    "description": "Nothing. Just a NewTab extension with random quote!",
    "browser_specific_settings": {
        "gecko": {
            "id": "your-newtab@fuongz.github.io",
            "strict_min_version": "109.0",
            "data_collection_permissions": {
                "required": [
                    "none"
                ],
                "optional": []
            }
        }
    },
    "chrome_url_overrides": {
        "newtab": "newtab.html"
    },
    "permissions": [
        "storage"
    ],
    "icons": {
        "48": "icons8-quote-48.png",
        "128": "icons8-quote-48.png"
    },
    "action": {
        "default_icon": "icons8-quote-50.png"
    }
}